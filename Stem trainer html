<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stemming Trainer</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f0f0f;--surface:#1a1a1a;--surface2:#242424;--border:#2a2a2a;
  --text:#f0f0f0;--muted:#666;--muted2:#888;
  --accent:#c8f560;--accent-dim:#8aab35;
  --danger:#ff5c5c;--warning:#f0a04b;--success:#4bdd8a;
  --orange:#ff8c42;
  --radius:10px;--mono:'DM Mono',monospace;--sans:'DM Sans',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:2rem 1rem 4rem}
header{text-align:center;margin-bottom:2rem}
header h1{font-family:var(--mono);font-size:clamp(1.5rem,4vw,2.2rem);font-weight:500;color:var(--accent);margin-bottom:0.3rem;letter-spacing:-0.02em}
header p{font-size:0.78rem;color:var(--muted2);font-family:var(--mono)}
.container{width:100%;max-width:560px}
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1.5rem}
.mode-btn{padding:10px 8px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);color:var(--muted2);cursor:pointer;font-family:var(--mono);font-size:0.72rem;transition:all 0.15s;text-align:center;line-height:1.5;width:100%}
.mode-btn:hover{border-color:#3a3a3a;color:var(--text)}
.mode-btn .mt{font-weight:500;font-size:0.76rem;display:block}
.mode-btn .ms{font-size:0.67rem;opacity:0.65;display:block;margin-top:2px}
.mode-btn.ae{border-color:var(--accent);color:var(--accent);background:#1a200a}
.mode-btn.ah{border-color:#7ec8f0;color:#7ec8f0;background:#0a1520}
.mode-btn.awe{border-color:var(--orange);color:var(--orange);background:#1f130a}
.mode-btn.awh{border-color:var(--danger);color:var(--danger);background:#1f0a0a}
.wb{display:inline-block;background:#2a1a0a;color:var(--orange);border:1px solid #4a2a10;border-radius:20px;font-size:0.65rem;padding:1px 7px;margin-left:5px;vertical-align:middle}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1.5rem}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px;text-align:center}
.stat-label{font-size:0.68rem;color:var(--muted2);font-family:var(--mono);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em}
.stat-val{font-size:1.4rem;font-weight:500;font-family:var(--mono)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:1rem}
.card-label{font-size:0.68rem;color:var(--muted2);font-family:var(--mono);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem}
.badge{display:inline-block;border-radius:6px;font-size:0.7rem;font-family:var(--mono);padding:3px 10px;margin-bottom:0.75rem}
.bff{background:#1a0f0f;color:#ff9a6c;border:1px solid #5a2a1a}
.bwr{background:#1f130a;color:var(--orange);border:1px solid #5a2a10}
#base-display{font-family:var(--mono);font-size:clamp(1.1rem,3vw,1.5rem);font-weight:500;color:var(--text);line-height:1.6;word-break:break-all}
.nl{display:inline-block;background:#1a200a;color:var(--accent);border:1px solid var(--accent-dim);border-radius:6px;padding:1px 8px;font-size:0.9em;margin:0 2px}
#scrambled-display{font-family:var(--mono);font-size:clamp(1.3rem,4vw,1.9rem);font-weight:500;color:var(--text);letter-spacing:0.15em;word-break:break-all}
.timer-row{display:flex;align-items:center;gap:12px;margin-bottom:0.75rem}
.timer-num{font-family:var(--mono);font-size:0.85rem;color:var(--muted2);min-width:26px;text-align:right}
.timer-track{flex:1;height:3px;background:var(--surface2);border-radius:2px;overflow:hidden}
#timer-bar{height:3px;width:100%;border-radius:2px;transition:width 0.1s linear,background 0.3s}
.typing-indicator{font-size:0.68rem;font-family:var(--mono);color:var(--muted);min-height:16px;margin-bottom:6px;transition:color 0.2s}
.typing-indicator.active{color:var(--warning)}
#answer-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;font-family:var(--mono);font-size:1.2rem;color:var(--text);letter-spacing:0.1em;text-transform:uppercase;outline:none;transition:border-color 0.15s}
#answer-input:focus{border-color:#3a3a3a}
#answer-input:disabled{opacity:0.5}
#answer-input.ic{border-color:var(--success)}
#answer-input.iw{border-color:var(--danger)}
.ans-meta{font-size:0.7rem;color:var(--muted);font-family:var(--mono);margin-top:6px}
#feedback{min-height:22px;font-size:0.83rem;font-family:var(--mono);margin-top:8px}
.fc{color:var(--success)}.fw{color:var(--danger)}.fm{color:var(--muted2)}
#reveal-text{font-family:var(--mono);font-size:0.85rem;color:var(--muted2);margin-top:6px;min-height:18px}
.rw{color:var(--text);font-weight:500}
.btn-row{display:flex;gap:8px;margin-top:1rem;flex-wrap:wrap}
.btn{padding:9px 18px;border-radius:var(--radius);border:1px solid var(--border);background:var(--surface);color:var(--muted2);cursor:pointer;font-family:var(--mono);font-size:0.78rem;transition:all 0.15s}
.btn:hover{border-color:#3a3a3a;color:var(--text)}
.btn:active{transform:scale(0.97)}
.btn-go{border-color:var(--accent-dim);color:var(--accent);background:#1a200a}
.btn-go:hover{background:#202b0d}
#progress-bar-wrap{height:2px;background:var(--surface2);border-radius:1px;margin-bottom:1.5rem;overflow:hidden}
#progress-bar{height:2px;background:var(--border);border-radius:1px;transition:width 0.4s}
#empty-state{text-align:center;padding:2.5rem 1rem;font-family:var(--mono);color:var(--muted2);background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:1rem;display:none}
#empty-state p:first-child{font-size:0.9rem;color:var(--text);margin-bottom:0.5rem}
#empty-state p{font-size:0.78rem}
#empty-state span{color:var(--accent)}
</style>
</head>
<body>
<header>
  <h1>stemming</h1>
  <p>word + letter → anagram</p>
</header>
<div class="container">
  <div class="mode-grid">
    <button class="mode-btn ae" id="btn-easy" onclick="setMode('easy')">
      <span class="mt">easy</span><span class="ms">word + letter · 10s</span>
    </button>
    <button class="mode-btn" id="btn-hard" onclick="setMode('hard')">
      <span class="mt">hard</span><span class="ms">all scrambled · 30s</span>
    </button>
    <button class="mode-btn" id="btn-wrong-easy" onclick="setMode('wrong-easy')">
      <span class="mt">easy — incorrect <span class="wb" id="wb-easy">0</span></span>
      <span class="ms">word + letter · 10s</span>
    </button>
    <button class="mode-btn" id="btn-wrong-hard" onclick="setMode('wrong-hard')">
      <span class="mt">hard — incorrect <span class="wb" id="wb-hard">0</span></span>
      <span class="ms">all scrambled · 30s</span>
    </button>
  </div>

  <div id="progress-bar-wrap"><div id="progress-bar" style="width:0%"></div></div>

  <div class="stats-row">
    <div class="stat"><div class="stat-label">Score</div><div class="stat-val" id="score">0</div></div>
    <div class="stat"><div class="stat-label">Streak</div><div class="stat-val" id="streak">0</div></div>
    <div class="stat"><div class="stat-label">Round</div><div class="stat-val" id="round">1</div></div>
  </div>

  <div id="empty-state">
    <p>no incorrect answers yet</p>
    <p>play <span>easy</span> or <span>hard</span> mode — any miss or reveal gets saved here</p>
  </div>

  <div id="game-area">
    <div class="card">
      <div class="card-label" id="puzzle-label">base word</div>
      <div id="badge-ff" class="badge bff" style="display:none">false friend</div>
      <div id="badge-wr" class="badge bwr" style="display:none">from incorrect list</div>
      <div id="easy-section"><div id="base-display"></div></div>
      <div id="hard-section" style="display:none"><div id="scrambled-display"></div></div>
    </div>

    <div class="card">
      <div class="card-label">your answer</div>
      <div class="timer-row">
        <div class="timer-num" id="timer-num">10</div>
        <div class="timer-track"><div id="timer-bar"></div></div>
      </div>
      <div class="typing-indicator" id="typing-ind"></div>
      <input id="answer-input" type="text" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" placeholder="start typing...">
      <div class="ans-meta" id="ans-meta"></div>
      <div id="feedback"></div>
      <div id="reveal-text"></div>
    </div>

    <div class="btn-row">
      <button class="btn" onclick="revealAnswer()">reveal</button>
      <button class="btn" onclick="nextPuzzle()">skip →</button>
    </div>
  </div>
</div>


function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}

const puzzles=RAW.filter(p=>{
  if(p[3])return true;
  const src=(p[0]+p[1]).toLowerCase().split("").sort().join("");
  return p[2].some(a=>a.toLowerCase().split("").sort().join("")===src);
});

const WRONG_KEY='stemming_wrong_v2';
function loadWrong(){try{return JSON.parse(localStorage.getItem(WRONG_KEY)||'[]')}catch(e){return[]}}
function saveWrong(a){localStorage.setItem(WRONG_KEY,JSON.stringify(a))}
function pkey(p){return p[0]+'||'+p[1]+'||'+p[2].join(',')}
function addToWrong(p){
  const arr=loadWrong(),k=pkey(p);
  if(!arr.find(x=>pkey(x)===k)){arr.push(p);saveWrong(arr);}
  updateBadges();
}
function updateBadges(){
  const n=loadWrong().length;
  document.getElementById('wb-easy').textContent=n;
  document.getElementById('wb-hard').textContent=n;
}

const TMAX={'easy':10,'hard':30,'wrong-easy':10,'wrong-hard':30};
const ISCRAM={'easy':false,'hard':true,'wrong-easy':false,'wrong-hard':true};
const TYPING_WINDOW=5;

let mode='easy';
let mainOrd=shuffle([...Array(puzzles.length).keys()]);
let wrongOrd=[];
let idx=0,score=0,streak=0,roundNum=1;
let mainIv=null,typingIv=null;
let mainTime=10,typingTime=TYPING_WINDOW;
let phase='main'; // 'main' | 'typing' | 'done'
let current=null;

function isWrong(){return mode==='wrong-easy'||mode==='wrong-hard';}

function setMode(m){
  mode=m;
  ['easy','hard','wrong-easy','wrong-hard'].forEach(id=>{
    document.getElementById('btn-'+id).className='mode-btn';
  });
  const cls={'easy':'ae','hard':'ah','wrong-easy':'awe','wrong-hard':'awh'};
  document.getElementById('btn-'+m).classList.add(cls[m]);
  score=0;streak=0;roundNum=1;idx=0;
  document.getElementById('score').textContent=0;
  document.getElementById('streak').textContent=0;
  if(isWrong()){
    const w=loadWrong();
    if(w.length===0){
      document.getElementById('game-area').style.display='none';
      document.getElementById('empty-state').style.display='block';
      return;
    }
    wrongOrd=shuffle([...Array(w.length).keys()]);
  } else {
    mainOrd=shuffle([...Array(puzzles.length).keys()]);
  }
  document.getElementById('game-area').style.display='';
  document.getElementById('empty-state').style.display='none';
  loadPuzzle();
}

function getList(){return isWrong()?loadWrong():puzzles;}
function getOrd(){return isWrong()?wrongOrd:mainOrd;}
function scramble(s){return shuffle(s.toUpperCase().split("")).join(" ");}

function loadPuzzle(){
  const list=getList(),ord=getOrd();
  if(idx>=ord.length){
    if(isWrong())wrongOrd=shuffle([...Array(list.length).keys()]);
    else mainOrd=shuffle([...Array(puzzles.length).keys()]);
    idx=0;
  }
  current=getList()[getOrd()[idx]];
  phase='main';
  clearInterval(mainIv);clearInterval(typingIv);
  mainTime=TMAX[mode];typingTime=TYPING_WINDOW;

  const inp=document.getElementById('answer-input');
  inp.value='';inp.disabled=false;inp.className='';
  document.getElementById('feedback').textContent='';
  document.getElementById('feedback').className='';
  document.getElementById('reveal-text').textContent='';
  document.getElementById('round').textContent=roundNum;
  document.getElementById('ans-meta').textContent=current[2][0].length+' letters';
  document.getElementById('typing-ind').textContent='';
  document.getElementById('typing-ind').className='typing-indicator';

  const ff=current[3];
  document.getElementById('badge-ff').style.display=ff?'inline-block':'none';
  document.getElementById('badge-wr').style.display=isWrong()?'inline-block':'none';

  if(!ISCRAM[mode]){
    document.getElementById('easy-section').style.display='';
    document.getElementById('hard-section').style.display='none';
    document.getElementById('puzzle-label').textContent=ff?'this word is a false friend:':'base word + new letter';
    if(ff){
      document.getElementById('base-display').textContent=current[0].toUpperCase();
    } else {
      const badges=current[1].toUpperCase().split("").map(l=>`<span class="nl">${l}</span>`).join('');
      document.getElementById('base-display').innerHTML=current[0].toUpperCase()+' + '+badges;
    }
  } else {
    document.getElementById('easy-section').style.display='none';
    document.getElementById('hard-section').style.display='';
    document.getElementById('puzzle-label').textContent=ff?'unscramble — false friend':'unscramble all letters';
    document.getElementById('scrambled-display').textContent=scramble(current[0]+current[1]);
  }

  updateBar(mainTime,TMAX[mode]);
  document.getElementById('timer-num').textContent=Math.ceil(mainTime);
  mainIv=setInterval(tickMain,100);
  inp.focus();

  const total=getList().length;
  document.getElementById('progress-bar').style.width=Math.round((idx/Math.max(total,1))*100)+'%';
}

function tickMain(){
  mainTime=Math.max(0,mainTime-0.1);
  document.getElementById('timer-num').textContent=Math.ceil(mainTime);
  updateBar(mainTime,TMAX[mode]);
  if(mainTime<=0){clearInterval(mainIv);timeUp();}
}

function tickTyping(){
  typingTime=Math.max(0,typingTime-0.1);
  document.getElementById('timer-num').textContent=Math.ceil(typingTime);
  updateBar(typingTime,TYPING_WINDOW);
  if(typingTime<=0){clearInterval(typingIv);timeUp();}
}

function updateBar(t,max){
  const pct=(t/max)*100;
  const bar=document.getElementById('timer-bar');
  bar.style.width=Math.max(0,pct)+'%';
  const r=t/max;
  bar.style.background=r>0.5?'#c8f560':r>0.25?'#f0a04b':'#ff5c5c';
}

function startTypingPhase(){
  if(phase!=='main')return;
  phase='typing';
  clearInterval(mainIv);
  typingTime=TYPING_WINDOW;
  document.getElementById('typing-ind').textContent='5s to answer';
  document.getElementById('typing-ind').className='typing-indicator active';
  typingIv=setInterval(tickTyping,100);
}

function timeUp(){
  if(phase==='done')return;
  phase='done';
  streak=0;document.getElementById('streak').textContent=0;
  const inp=document.getElementById('answer-input');
  inp.disabled=true;inp.className='iw';
  setFb('time up','fm');
  document.getElementById('typing-ind').textContent='';
  addToWrong(current);
  showAns();
}

function showAns(){
  const words=current[2].map(w=>`<span class="rw">${w.toUpperCase()}</span>`).join(' / ');
  document.getElementById('reveal-text').innerHTML='→ '+words;
}

function setFb(txt,cls){
  const el=document.getElementById('feedback');
  el.textContent=txt;el.className=cls;
}

document.getElementById('answer-input').addEventListener('input',function(){
  if(phase==='done')return;
  const val=this.value.trim().toLowerCase();
  if(val.length>0 && phase==='main') startTypingPhase();
  if(val.length===0 && phase==='typing'){
    // cleared — don't resume main, keep typing window
  }
  if(current[2].map(a=>a.toLowerCase()).includes(val)){
    clearInterval(mainIv);clearInterval(typingIv);
    phase='done';score++;streak++;
    document.getElementById('score').textContent=score;
    document.getElementById('streak').textContent=streak;
    this.disabled=true;this.className='ic';
    setFb('correct','fc');
    document.getElementById('typing-ind').textContent='';
    updateBar(1,1);
    document.getElementById('timer-num').textContent='✓';
    setTimeout(nextPuzzle,700);
  }
});

function revealAnswer(){
  if(phase==='done')return;
  clearInterval(mainIv);clearInterval(typingIv);
  phase='done';streak=0;
  document.getElementById('streak').textContent=0;
  const inp=document.getElementById('answer-input');
  inp.disabled=true;inp.className='iw';
  document.getElementById('typing-ind').textContent='';
  setFb('revealed','fm');
  addToWrong(current);
  showAns();
}

function nextPuzzle(){idx++;roundNum++;loadPuzzle();}

updateBadges();
loadPuzzle();
</script>
